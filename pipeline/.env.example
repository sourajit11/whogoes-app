# Supabase (required)
SUPABASE_URL=https://citrznhubxqvsfhjkssg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini API for personalization (optional - falls back to templates)
GEMINI_API_KEY=your-gemini-api-key

# Google Sheets OAuth2 (required for production)
# Create OAuth2 Client ID (Desktop app) in Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Run: node pipeline/get-refresh-token.mjs to get this
GOOGLE_REFRESH_TOKEN=your-refresh-token
# Sheet ID is the long string in the URL: docs.google.com/spreadsheets/d/{THIS_PART}/edit
GOOGLE_SHEET_ID=your-google-sheet-id

# Slack webhook (optional - skips notification if not set)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
