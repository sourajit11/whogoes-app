# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase - public (safe to expose, used by browser)
NEXT_PUBLIC_SUPABASE_URL=https://citrznhubxqvsfhjkssg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase - server-only secrets. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Used by scripts in app/scripts/ that need admin access:
#   - dump-event-slugs.mjs
#   - prune-event-pages.mjs

# Internal email automation (Resend + queue processor)
RESEND_API_KEY=
# Shared secret protecting /api/email/process and /api/email/unsubscribe (used by n8n)
EMAIL_CRON_SECRET=

# Shared secret protecting /api/pipeline/extract and /api/pipeline/commit (used by n8n
# "WhoGoes Leads -> Plusvibe" workflow that pulls daily outreach contacts)
PIPELINE_CRON_SECRET=

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# IndexNow
INDEXNOW_SECRET=c46c644d8da9be79f7cf73acfccfb6ac

# Analytics
