# dependencies
/node_modules
/pipeline/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# vercel
.vercel

# claude
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# generated data & exports (contain PII — never commit)
/scripts/output/
/scripts/invoices/
/scripts/__pycache__/
/scripts/exported-upcoming-emails.json

# scratch / one-off diagnostics
/scripts/diag_role*.mjs
/scripts/e2e-*.mjs

